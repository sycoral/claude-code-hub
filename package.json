    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/swagger-ui": "^0.5",
    "@hono/zod-openapi": "^1",
