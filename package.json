    "react-hook-form": "^7",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16",
    "recharts": "^3",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "safe-regex": "^2",
    "server-only": "^0.0.1",
    "sonner": "^2",
    "tailwind-merge": "^3",
    "timeago.js": "^4",
    "tw-animate-css": "^1",
