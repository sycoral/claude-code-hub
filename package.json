    "@types/ioredis": "^5",
    "@types/node": "^24",
    "@types/pg": "^8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15",
    "@typescript/native-preview": "7.0.0-dev.20260321.1",
    "@vitest/coverage-v8": "^4",
    "@vitest/ui": "^4",
    "bun-types": "^1",
